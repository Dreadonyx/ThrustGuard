# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environment ────────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Eclipse / ThrustGuard runtime files ───────────────────────────────────────
eclipse.db          # SQLite database (generated at runtime)
eclipse.db-wal      # WAL journal
eclipse.db-shm      # Shared memory file
*.db
*.db-wal
*.db-shm

# ── Auto-generated policy files for specific device instances ─────────────────
# Keep the base type policies (camera.json, bulb.json, sensor.json)
# but ignore auto-generated per-device-id policies (cam-01.json, etc.)
policies/cam-*.json
policies/bulb-*.json
policies/sensor-*.json

# ── Test / debug scripts ───────────────────────────────────────────────────────
test_attack.py

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── OS junk ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Environment variables ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Misc ──────────────────────────────────────────────────────────────────────
*.zip
files.zip
